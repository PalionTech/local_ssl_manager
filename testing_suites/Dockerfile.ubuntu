FROM ubuntu:latest

RUN apt-get update && apt-get install -y python3 python3-pip python3-venv sudo curl openssl

# Create a test user with sudo access
RUN useradd -m testuser && echo "testuser ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/testuser

# Switch to test user
USER testuser
WORKDIR /home/testuser

# Create and activate a virtual environment
RUN python3 -m venv /home/testuser/venv
ENV PATH="/home/testuser/venv/bin:$PATH"

# Install your package in the virtual environment
RUN pip install local-ssl-manager

# Keep the container running
CMD ["bash"]
